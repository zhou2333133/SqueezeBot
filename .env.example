# Binance Futures API（主账户：scalp + 手动下单 + 余额查询走这把）
BINANCE_API_KEY="your_binance_api_key_here"
BINANCE_API_SECRET="your_binance_api_secret_here"

# V4AF 闪崩模块独立账户（建议另开一个币安账户，与 scalp 隔离）
# 留空则回退到主账户（不推荐，因为风控/仓位会和 scalp 互相影响）
BINANCE_FLASH_API_KEY=""
BINANCE_FLASH_API_SECRET=""

# Web 控制台安全
# 默认仅本机访问；设置 PANEL_TOKEN 后首次打开面板需输入一次。
PANEL_HOST="127.0.0.1"
PANEL_PORT="8000"
PANEL_TOKEN=""

# Surf.ai — 新闻过滤 + 清算热图 + AI Agent 评分
# 申请: https://asksurf.ai
SURF_API_KEY="your_surf_api_key_here"
# 入场/终审需要低延迟，默认用 surf-ask；需要更强推理时可改 surf-1.5-instant / surf-1.5。
# 注意：Chat API 按次计费较高，默认策略配置关闭后台 Surf AI 调用。
SURF_CHAT_MODEL="surf-ask"
SURF_CHAT_BACKOFF_SECONDS="600"

# OKX OnChainOS DEX Market API — 链上数据二次确认
# 申请: https://web3.okx.com/build/dev-portal (创建项目后生成 API Key)
OKX_API_KEY="your_okx_api_key_here"
OKX_SECRET_KEY="your_okx_secret_key_here"
# OKX_PASSPHRASE 可选，创建 API Key 时若未设置 Passphrase 则留空或删除此行
OKX_PASSPHRASE=""

# Optional AI opportunity review.
# Keys stay in environment variables and are never saved from the Web panel.
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# Binance Square 使用公开页面浏览器采集。
# 如页面要求登录，请只在本机弹出的浏览器窗口手动登录自己的账号；
# 不要把 cookie、csrf、token 或账号凭证粘贴到配置或聊天里。

# 妖币雷达 推送通知（v2.8 三层决策面板，每次扫描完发 L1/L2 信号汇总）
# Telegram: 找 @BotFather 创建 bot 拿 token；自己跟 bot 说一句话后用
#   https://api.telegram.org/bot<TOKEN>/getUpdates 看 chat id
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Discord: 频道设置 → 整合 → Webhook → 复制 URL
DISCORD_WEBHOOK_URL=""
# 启用要在 UI 设置 YAOBI_NOTIFIER_ENABLED=true（默认 false 不推送）
