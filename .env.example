# Binance Futures API
BINANCE_API_KEY="your_binance_api_key_here"
BINANCE_API_SECRET="your_binance_api_secret_here"

# Web 控制台安全
# 默认仅本机访问；设置 PANEL_TOKEN 后首次打开面板需输入一次。
PANEL_HOST="127.0.0.1"
PANEL_PORT="8000"
PANEL_TOKEN=""

# Surf.ai — 新闻过滤 + 清算热图 + AI Agent 评分
# 申请: https://asksurf.ai
SURF_API_KEY="your_surf_api_key_here"
# 入场/终审需要低延迟，默认用 surf-ask；需要更强推理时可改 surf-1.5-instant / surf-1.5。
# 注意：Chat API 按次计费较高，默认策略配置关闭后台 Surf AI 调用。
SURF_CHAT_MODEL="surf-ask"
SURF_CHAT_BACKOFF_SECONDS="600"

# OKX OnChainOS DEX Market API — 链上数据二次确认
# 申请: https://web3.okx.com/build/dev-portal (创建项目后生成 API Key)
OKX_API_KEY="your_okx_api_key_here"
OKX_SECRET_KEY="your_okx_secret_key_here"
# OKX_PASSPHRASE 可选，创建 API Key 时若未设置 Passphrase 则留空或删除此行
OKX_PASSPHRASE=""

# Binance Square — 如需绕过 WAF，填浏览器 Cookie；建议使用单独小号。
BINANCE_SQUARE_COOKIE=""
BINANCE_SQUARE_CSRF_TOKEN=""
BINANCE_SQUARE_BNC_UUID=""
BINANCE_SQUARE_OPENAPI_KEY=""
